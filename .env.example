# Copy to .env (root level is unused; per-app .env files live in apps/*/.env)
# This file documents every variable the platform requires.

# ── App ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ── Database (PostgreSQL — Supabase or Render) ──────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/noni

# ── Cache / queue / pub-sub (Upstash Redis) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-rs256-private-key
JWT_REFRESH_SECRET=replace-with-256-bit-secret
OTP_SALT=replace-with-random-secret
PHONE_HASH_SALT=replace-with-random-secret

# ── Payments (Flutterwave primary) ──────────────────────────────────────
# Empty FLW_SECRET_KEY = dev mode (simulated checkout via /v1/payments/dev/complete).
# FLW_WEBHOOK_HASH must match the dashboard "secret hash" (verif-hash header).
FLW_SECRET_KEY=
FLW_WEBHOOK_HASH=
FLW_REDIRECT_URL=https://noni.ng/payment/complete

# ── AI / LLM (Anthropic Claude) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SMS / OTP ───────────────────────────────────────────────────────────
# auto = SMS Gate if configured, else Termii, else console log (dev).
SMS_PROVIDER=auto
TERMII_API_KEY=
TERMII_SENDER_ID=Noni
SMSGATE_BASE_URL=https://api.sms-gate.app/3rdparty/v1
SMSGATE_USERNAME=
SMSGATE_PASSWORD=

# ── Agent-note encryption (F-017): openssl rand -hex 32 ─────────────────
NOTE_ENCRYPTION_KEY=

# ── Safety (S-003): on-call supervisor phone for crisis SMS ─────────────
SUPERVISOR_PHONE=

# ── Push notifications (Firebase Cloud Messaging) ───────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
LOG_LEVEL=info

# ── WebRTC / TURN (self-hosted Coturn) ──────────────────────────────────
TURN_SERVER_URL=turn:turn.noni.ng:3478
TURN_SHARED_SECRET=replace-with-coturn-shared-secret

# ── Mobile app (Expo) ───────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:3000
