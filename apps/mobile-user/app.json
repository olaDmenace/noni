{
  "expo": {
    "name": "Noni",
    "slug": "noni-user",
    "scheme": "noni",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#0E0B0A",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0E0B0A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.noni.user",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Noni needs microphone access for voice sessions with listeners.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ng.noni.user",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiBaseUrl": "https://noni-api.onrender.com",
      "wsBaseUrl": "wss://noni-api.onrender.com",
      "eas": {
        "projectId": "e764b43a-2f6d-48db-b9cf-ea54937ba6df"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": false,
          "microphonePermission": "Noni needs microphone access for voice sessions with listeners."
        }
      ]
    ],
    "owner": "oladmenace",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e764b43a-2f6d-48db-b9cf-ea54937ba6df"
    }
  }
}
