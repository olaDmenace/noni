{
  "expo": {
    "name": "Noni Agent",
    "slug": "noni-agent",
    "scheme": "noniagent",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#0E0B0A",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0E0B0A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.noni.agent",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Noni Agent needs microphone access for voice sessions.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ng.noni.agent",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0B0A"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiBaseUrl": "https://noni-api.onrender.com",
      "wsBaseUrl": "wss://noni-api.onrender.com",
      "eas": {
        "projectId": "3a7af4c4-0a6b-47e2-acd2-c9aa8c900ff9"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": false,
          "microphonePermission": "Noni Agent needs microphone access for voice sessions."
        }
      ]
    ],
    "owner": "oladmenace",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3a7af4c4-0a6b-47e2-acd2-c9aa8c900ff9"
    }
  }
}
