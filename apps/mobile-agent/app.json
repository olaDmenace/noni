{
  "expo": {
    "name": "Noni Agent",
    "slug": "noni-agent",
    "scheme": "noniagent",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#0E0B0A",
    "splash": {
      "backgroundColor": "#0E0B0A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.noni.agent",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Noni Agent needs microphone access for voice sessions."
      }
    },
    "android": {
      "package": "ng.noni.agent",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000",
      "wsBaseUrl": "ws://localhost:3000"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ]
  }
}
