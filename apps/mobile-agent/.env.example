# Copy to .env for local dev. Expo reads EXPO_PUBLIC_* vars at build time.

# Point at the API. Pick the right host for your test target:
#   iOS simulator:      http://localhost:3000
#   Android emulator:   http://10.0.2.2:3000
#   Physical phone:     http://<your-machine-LAN-IP>:3000   (e.g. http://192.168.1.42:3000)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:3000
