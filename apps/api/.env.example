# Copy to .env for local dev. Production secrets live in the host secret manager.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_BASE_URL=http://localhost:3000

# ── Database (Supabase Postgres) ────────────────────────────────────────
# DATABASE_URL = pooled connection (port 6543, transaction mode) — used at runtime.
# DIRECT_URL   = direct connection (port 5432) — used by `prisma migrate`.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Cache / Pub-Sub (Upstash Redis) ─────────────────────────────────────
# Use the rediss:// (TLS) URL from Upstash → Connect → ioredis.
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Auth secrets (generate fresh 32+ char strings for each) ─────────────
JWT_ACCESS_SECRET=dev-only-change-me-access-1234567890
JWT_REFRESH_SECRET=dev-only-change-me-refresh-1234567890
OTP_SALT=dev-only-change-me-otp-salt
PHONE_HASH_SALT=dev-only-change-me-phone-salt

# ── Payments (Flutterwave) ──────────────────────────────────────────────
# Empty FLW_SECRET_KEY = dev mode: initiate returns a fake checkout link and
# POST /v1/payments/dev/complete simulates the webhook (blocked in production).
#
# FLW_WEBHOOK_HASH is OPTIONAL. Payment confirmation is webhook-independent:
# the app verifies by tx_ref (GET /v3/transactions/verify_by_reference) on
# checkout return, plus a background poll for stragglers. This lets the same
# Flutterwave account serve another product whose dashboard webhook URL is
# already taken. Set the hash only if you later point the webhook at Noni.
FLW_SECRET_KEY=
FLW_WEBHOOK_HASH=
FLW_REDIRECT_URL=https://noni.ng/payment/complete

# ── Agent-note encryption (F-017) ───────────────────────────────────────
# 64 hex chars (32 bytes). Generate: openssl rand -hex 32
NOTE_ENCRYPTION_KEY=

# ── Safety (S-003) ──────────────────────────────────────────────────────
# On-call supervisor phone for crisis SMS alerts (E.164, e.g. +2348012345678).
SUPERVISOR_PHONE=

# ── AI (Anthropic Claude) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SMS / OTP ───────────────────────────────────────────────────────────
# SMS_PROVIDER: auto | termii | smsgate | dev
#   auto (default): smsgate if its credentials are set, else termii, else dev (log only).
SMS_PROVIDER=auto

# Termii — production route (requires a registered business).
TERMII_API_KEY=
TERMII_SENDER_ID=Noni

# SMS Gate (sms-gate.app) — dev/beta route, sends through an Android phone's SIM.
# Install the app, enable Cloud server mode, copy the login/password it shows.
SMSGATE_BASE_URL=https://api.sms-gate.app/3rdparty/v1
SMSGATE_USERNAME=
SMSGATE_PASSWORD=

# ── Push notifications (Firebase) ───────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=

# ── WebRTC TURN ─────────────────────────────────────────────────────────
TURN_SERVER_URL=turn:turn.noni.ng:3478
TURN_SHARED_SECRET=replace-me
