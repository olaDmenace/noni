{
  "name": "@noni/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate || echo \"skipping prisma generate (no schema yet)\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@noni/ai-prompt": "*",
    "@noni/types": "*",
    "@prisma/client": "^5.18.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "pdfkit": "^0.19.1",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@noni/config": "*",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.18.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "~5.9.2",
    "vitest": "^2.0.4"
  }
}
